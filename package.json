{
  "name": "Corevia",
  "private": true,
  "scripts": {
    "ruler:apply": "npx @intellectronica/ruler@latest apply --local-only",
    "check:all": "turbo check:all",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:home": "turbo -F home dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:app": "turbo dev -F corevia-app -F server",
    "dev:backoffice": "turbo dev dev:devtools -F web -F server",
    "db:push": "turbo -F server db:push",
    "db:studio": "turbo -F server db:studio",
    "db:generate": "turbo -F server db:generate",
    "db:reset": "turbo -F server db:reset",
    "db:migrate": "turbo -F server db:migrate",
    "db:seed": "turbo -F server db:seed",
    "db:check": "turbo -F server db:check",
    "format": "biome check --write .",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "h3": ">=1.15.6",
      "glob": ">=11.1.0",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "defu": ">=6.1.5",
      "basic-ftp": ">=5.2.1"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.12.1"
}
