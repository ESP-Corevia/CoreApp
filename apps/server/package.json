{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "pnpm build && node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx ./scripts/authSeed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx ./scripts/dbReset.ts",
    "db:check": "drizzle-kit check",
    "build:types": "echo '📦 Building server types...' && tsc --build tsconfig.build.json --verbose",
    "check:lint": "biome check . && echo 🚨✅ Lint check passed! || (echo ❌ Lint failed 💥 && exit 1)",
    "check:types": "tsc -p tsconfig.typecheck.json && echo 🧠✅ Type check passed!",
    "format": "biome check --write .",
    "check:knip": "knip && echo ✂️✅ Unused code check passed!",
    "check:dep": "depcheck && echo 📦✅ Dependency check passed!",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "check:test": "vitest run  && echo 🧪✅ Tests passed! || (echo '❌ Fix the above issues before committing 💡' && exit 1)",
    "check:all": "pnpm check:lint && pnpm check:types && pnpm check:knip && pnpm check:dep && pnpm build:types && pnpm build"
  },
  "dependencies": {
    "@fastify/cors": "11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@scalar/fastify-api-reference": "1.34.2",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "cfonts": "3.3.1",
    "chalk": "5.6.2",
    "dotenv": "17.2.1",
    "drizzle-orm": "0.45.1",
    "fastify": "5.8.4",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.1",
    "superjson": "2.2.2",
    "vite-tsconfig-paths": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.1",
    "@faker-js/faker": "catalog:",
    "@scalar/fastify-api-reference": "1.34.2",
    "@types/node": "catalog:",
    "@types/pg": "8.20.0",
    "@vitest/coverage-istanbul": "3.2.4",
    "@vitest/ui": "catalog:",
    "depcheck": "catalog:",
    "drizzle-kit": "0.31.10",
    "drizzle-seed": "0.3.1",
    "knip": "catalog:",
    "trpc-to-openapi": "3.1.0",
    "tsdown": "0.19.0",
    "tsx": "4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-mock-extended": "3.1.0",
    "zod-openapi": "5.3.1"
  },
  "packageManager": "pnpm@10.12.1",
  "version": "1.1.1"
}
