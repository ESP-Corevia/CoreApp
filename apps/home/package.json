{
  "name": "home",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "format": "biome check --write .",
    "typecheck": "react-router typegen && tsc",
    "check:lint": "biome check . && echo 🔎✅ Lint suite passed! || (echo ❌ Lint failed 💥 && exit 1)",
    "check:types": "react-router typegen && tsc --noEmit && echo 🧠✅ Type check passed!",
    "check:knip": "react-router typegen && knip && echo ✂️✅ Unused code check passed!",
    "check:dep": "depcheck && echo 📦✅ Dependency check passed!",
    "check:all": "pnpm check:lint && pnpm check:types && pnpm check:knip && pnpm check:dep && pnpm build"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-router/fs-routes": "catalog:",
    "@react-router/node": "catalog:",
    "@react-router/serve": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "gsap": "^3.13.0",
    "isbot": "catalog:",
    "lucide-react": "catalog:",
    "motion": "12.23.25",
    "next-themes": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "devDependencies": {
    "@react-router/dev": "catalog:",
    "@tailwindcss/vite": "4.1.8",
    "@types/node": "catalog:",
    "@types/react": "~19.1.10",
    "@types/react-dom": "19.0.4",
    "depcheck": "catalog:",
    "knip": "catalog:",
    "react-router-devtools": "6.2.0",
    "shadcn": "catalog:",
    "tailwindcss": "4.1.8",
    "typescript": "catalog:",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "catalog:"
  },
  "packageManager": "pnpm@10.12.1",
  "version": "1.1.0"
}
