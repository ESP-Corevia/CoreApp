{
  "name": "corevia-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build && echo 🏗️✅ Build passed! || (echo ❌ Build failed 💥 && exit 1)",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "check:types": "pnpm --filter server build:types && react-router typegen && tsc --noEmit && echo 🧠✅ Type check passed! || (echo ❌ Type check failed 💥 && exit 1)",
    "check:lint": "biome check .",
    "format": "biome check --write . && echo 🧰✨ Codebase formatted",
    "i18n:status": "i18next-cli status",
    "i18n:extract": "i18next-cli extract && echo 🌍✅ i18n extraction passed! || (echo ❌ i18n extraction failed 💥 && exit 1)",
    "check:i18n": "i18next-cli extract --ci && echo 🌍✅ i18n check passed! || (echo ❌ i18n check failed 💥 && exit 1)"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.148",
